shell-integration=zsh
theme=Nvim Dark
font-size=14
font-family="Meslo LG S"
font-feature=-calt,-liga,-dlig
clipboard-trim-trailing-spaces=true
bell-features=no-audio
window-decoration=server
window-vsync=false
window-save-state=always

# zen
window-padding-x = 220
window-padding-balance=true
window-padding-color=extend

keybind = ctrl+shift+r=reload_config
keybind = ctrl+enter=unbind
keybind = ctrl+x=text:`w
keybind = ctrl+y=text:`c
keybind = ctrl+1=text:`1
keybind = ctrl+2=text:`2
keybind = ctrl+3=text:`3
keybind = ctrl+4=text:`4
keybind = ctrl+5=text:`5
keybind = ctrl+6=text:`6
keybind = ctrl+7=text:`7
keybind = ctrl+8=text:`8
keybind = ctrl+9=text:`9
