set $mod Mod4

# exec --no-startup-id xsetroot -solid "#000"

# repeat
exec_always --no-startup-id xset r rate 220 40
 
# kb
exec_always --no-startup-id setxkbmap -layout us,pl
bindsym $mod+Shift+grave exec "xkb-switch -n && notify-send -t 3000 \\"kb layout: $(xkb-switch -p)\\""

# applets / notifications
exec_always --no-startup-id mictray
exec --no-startup-id xmousepasteblock
exec --no-startup-id gxkb
# exec --no-startup-id dunst
exec --no-startup-id nm-applet
exec --no-startup-id pasystray
exec --no-startup-id ulauncher --hide-window
exec --no-startup-id caffeine start --activate --pulseaudio --fullscreen # prevent sleep
# exec --no-startup-id element-desktop

# Bobby
# set $mod Mod1
# exec --no-startup-id xrandr --output eDP --off

# HOME
# exec --no-startup-id xrandr --output HDMI-0 --mode 1920x1080 --rate 144
exec --no-startup-id xrandr --output DP-2 --mode 1920x1080 --rate 144

# WLAD dell
# exec --no-startup-id xrandr --output HDMI-0 --mode 2560x1440 --rate 120

# Caps as ctrl
exec --no-startup-id setxkbmap -option caps:ctrl_modifier

# Nightlight
exec --no-startup-id redshift -l 52.2297:21.0122 -t 6500:4500

# Global maccel for all devices
exec_always for id in $(xinput list | grep "pointer" | cut -d '=' -f 2 | cut -f 1); do xinput --set-prop $id 'libinput Accel Profile Enabled' 0, 1; done
# disable fast drag lag
exec_always for id in $(xinput list | grep "pointer" | cut -d '=' -f 2 | cut -f 1); do xinput --set-prop $id 'libinput Middle Emulation Enabled' 0; done

# No drag
tiling_drag off

# lock
set $lock_cmd "i3lock -B 10 --indicator"
exec --no-startup-id xss-lock -l -- $lock_cmd # set lock
bindsym $mod+Shift+y exec --no-startup-id $lock_cmd
# Sleep screen
# exec --no-startup-id xset s 600 # 5min screenlock
# exec --no-startup-id xautolock -time 10 -locker "systemctl suspend" -detectsleep # 10m sleep

# Disable titlebars
for_window [all] border pixel 1
for_window [all] title_window_icon on
hide_edge_borders smart

# screenshots
set $ss_path ~/Pictures/Screenshots
bindsym $mod+y exec --no-startup-id maim | tee $ss_path/screenshot_$(date +%Y%m%d_%H%M%S).png | xclip -selection clipboard -t image/png
bindsym $mod+u exec --no-startup-id maim --select | tee $ss_path/screenshot_$(date +%Y%m%d_%H%M%S).png | xclip -selection clipboard -t image/png
# bindsym $mod+i exec --no-startup-id maim --window $(xdotool selectwindow) | tee $ss_path/screenshot_$(date +%Y%m%d_%H%M%S).png | xclip -selection clipboard -t image/png

# general
font pango:DejaVu Sans Mono 9.5
default_orientation horizontal
workspace_layout tabbed
show_marks yes

floating_modifier $mod
floating_minimum_size 60 x 30
force_display_urgency_hint 500 ms
popup_during_fullscreen smart

# defaults
set $term ghostty
set $browser zen-twilight
set $music_app vlc
set $notes_app obsidian

# workspace bound windows
assign [class="zen"] 1
assign [class="firefox"] 1
assign [class="twilight"] 1
assign [class="*chrom*"] 1

assign [class="vlc"] 2
assign [class="obsidian"] 2

assign [class="ghostty"] 3

assign [class="Code"] 4
assign [class="dev.zed.Zed"] 4
assign [class="nvim"] 4

assign [class="sioyek"] 5
assign [class="Element"] 5
assign [class="steam"] 5
assign [class="steamwebhelper"] 5
assign [class="sioyek"] 5
assign [class="heroic"] 5

for_window [title="StarCraft II"] move to workspace 5
for_window [class="Ulauncher"] move workspace current
for_window [window_type="dialog"] move position mouse
 
# focus
focus_on_window_activation smart

bindsym $mod+a focus parent
bindsym $mod+s focus child

# Toggle sticky on floating windows only (Mod +MMB)
bindsym $mod+button2 exec --no-startup-id "i3-msg '[con_id=__focused__ floating] sticky toggle'"

# startup workspaces on login
exec --no-startup-id $music_app
exec --no-startup-id $notes_app
exec --no-startup-id $term
exec --no-startup-id zen-twilight

# per class prefs
for_window [title="Picture-in-Picture"] floating enable, resize set 140pt 80pt
for_window [title="Picture-in-Picture"] sticky enable

# per workspace layout prefs
for_window [class="steam_app_646570"] floating disable, layout tabbed # slay the spire

# aerospace-like
bindsym $mod+Return exec $term
bindsym $mod+n exec $browser
bindsym $mod+q kill
bindsym $mod+t exec thunar

bindsym $mod+d exec --no-startup-id "rofi -show combi || dmenu_run"
# bindsym $mod+d exec --no-startup-id "ulauncher || dmenu_run"

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+z split h
bindsym $mod+x split v

bindsym $mod+f fullscreen toggle
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+space floating toggle
bindsym $mod+Shift+space focus mode_toggle

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
# bindsym $mod+3 workspace number $ws3
bindsym $mod+3 workspace number 3:<span foreground="red">vim</span>
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace 1, workspace 1
bindsym $mod+Shift+2 move container to workspace 2, workspace 2
bindsym $mod+Shift+3 move container to workspace 3, workspace 3
bindsym $mod+Shift+4 move container to workspace 4, workspace 4
bindsym $mod+Shift+5 move container to workspace 5, workspace 5
bindsym $mod+Shift+6 move container to workspace 6, workspace 6
bindsym $mod+Shift+7 move container to workspace 7, workspace 7
bindsym $mod+Shift+8 move container to workspace 8, workspace 8
bindsym $mod+Shift+9 move container to workspace 9, workspace 9
bindsym $mod+Shift+0 move container to workspace 10, workspace 10

bindsym $mod+Shift+c restart
bindsym $mod+Shift+r reload

# bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'exit i3?' -B 'Yes, exit i3' 'i3-msg exit'"
# bindsym $mod+Shift+s exec "i3-nagbar -t warning -m 'suspend?' -B 'Yes, suspend' 'killall i3-nagbar && systemctl suspend'"

bindsym $mod+Shift+e exec --no-startup-id "killall i3-nagbar; i3-nagbar -t warning -m 'exit i3?' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+Shift+s exec --no-startup-id "killall i3-nagbar; i3-nagbar -t warning -m 'suspend?' -B 'Yes, suspend' 'systemctl suspend'"

# claude
bindsym $mod+apostrophe exec voxtype record toggle && notify-send -t 2000 "STT toggle"

# music
bindsym $mod+bracketleft exec playerctl previous
bindsym $mod+bracketright exec playerctl next
bindsym $mod+p exec playerctl play-pause
bindsym $mod+m exec i3-volume mute -n # system
bindsym $mod+Shift+m exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle # mic
bindsym $mod+minus exec i3-volume down 5 -n
bindsym $mod+equal exec i3-volume up 5 -n
bindsym --whole-window $mod+button9 exec playerctl next
bindsym --whole-window $mod+button8 exec playerctl previous

bindsym $mod+o mode "launcher"
mode "launcher" {
    bindsym q exec $browser
    bindsym w exec $notes_app
    bindsym t exec steam
    bindsym y exec heroic

    # l ctrl
    bindcode 37 mode "default"
    bindsym space mode "default"
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

bindsym $mod+r mode "resize"
mode "resize" {
  bindsym h resize shrink width 10 px or 10 ppt
  bindsym j resize grow height 10 px or 10 ppt
  bindsym k resize shrink height 10 px or 10 ppt
  bindsym l resize grow width 10 px or 10 ppt

  bindsym Left resize shrink width 10 px or 10 ppt
  bindsym Down resize grow height 10 px or 10 ppt
  bindsym Up resize shrink height 10 px or 10 ppt
  bindsym Right resize grow width 10 px or 10 ppt

  bindsym Return mode "default"
  bindsym Escape mode "default"
  bindsym $mod+r mode "default"
}

bar {
  position top
  # status_command i3status
  status_command i3status-rs ~/.config/i3status-rust/config-default.toml

}
